{
	email {$ACME_EMAIL}
}

http://localhost:3080, http://127.0.0.1:3080 {
	@hidden path_regexp hidden ^/(\.|.*/\.).*
	respond @hidden 404

	handle_path /tools* {
		@tools_denied {
			not path_regexp (?i)^/(?:$|.*/$|.*\.(?:html|js|mjs|css|json|map|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|eot|txt|webmanifest))$
		}
		respond @tools_denied 403
		root * /srv/tools
		file_server
	}

	reverse_proxy 127.0.0.1:3000
}

http://{$DOMAIN}:3080 {
	redir https://{$DOMAIN}{uri} 308
}

{$DOMAIN}:3443 {
	@hidden path_regexp hidden ^/(\.|.*/\.).*
	respond @hidden 404

	handle_path /tools* {
		@tools_denied {
			not path_regexp (?i)^/(?:$|.*/$|.*\.(?:html|js|mjs|css|json|map|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|eot|txt|webmanifest))$
		}
		respond @tools_denied 403
		root * /srv/tools
		file_server
	}

	reverse_proxy 127.0.0.1:3000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}
}
