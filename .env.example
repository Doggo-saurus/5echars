TZ=Etc/UTC
PUID=1000
PGID=1000

# Free dynamic DNS setup (https://www.duckdns.org)
DUCKDNS_SUBDOMAIN=your-subdomain
DUCKDNS_TOKEN=replace-with-duckdns-token
DOMAIN=your-subdomain.duckdns.org
MANUAL_BASE_URL=https://link to your favourite 5e tools

# ACME account email for Let's Encrypt notifications
ACME_EMAIL=you@example.com

# Use a long random value, at least 32 characters
REDIS_PASSWORD=replace-with-a-long-random-password
